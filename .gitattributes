# Normalize line endings; keep them LF in the repo.
* text=auto eol=lf

# Windows scripts stay CRLF.
*.bat text eol=crlf

# The Gradle wrapper script must stay LF (it's a POSIX shell script).
gradlew text eol=lf

# Binary assets — never touch.
*.jar binary
*.docx binary
*.png binary
*.ogg binary
*.ico binary
